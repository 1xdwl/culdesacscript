local remoteEvent = game:GetService("ReplicatedStorage"):WaitForChild("ClientToServer"):WaitForChild("DataEvents"):WaitForChild("EReplication")

local function getModelsInFolder(folderName)
    local models = {}
    local folder = workspace:FindFirstChild(folderName)
    if folder then
        for _, obj in pairs(folder:GetChildren()) do
            if obj:IsA("Model") then
                table.insert(models, obj)
            end
        end
    end
    return models
end

local function maintainExactlySeven(folderName)
    local folder = workspace:FindFirstChild(folderName)
    if not folder then return end
    local modelsByName = {}
    for _, model in pairs(folder:GetChildren()) do
        if model:IsA("Model") then
            local name = model.Name
            if not modelsByName[name] then
                modelsByName[name] = {}
            end
            table.insert(modelsByName[name], model)
        end
    end
    for name, models in pairs(modelsByName) do
        while #models > 7 do
            models[1]:Destroy()
            table.remove(models, 1)
        end
    end
end

local function spawnEntitiesAndBugs()
    local folderName = "EntityHandler"
    local folder = workspace:FindFirstChild(folderName)
    if not folder then return end
    local currentModels = {}
    for _, model in pairs(folder:GetChildren()) do
        if model:IsA("Model") then
            currentModels[model.Name] = currentModels[model.Name] or {}
            table.insert(currentModels[model.Name], model)
        end
    end
    for name, models in pairs(currentModels) do
        local count = #models
        local toSpawn = 7 - count
        for i=1,toSpawn do
            local sample = models[1]
            local pos = nil
            if sample then
                if sample:FindFirstChild("PrimaryPart") then
                    pos = sample.PrimaryPart.Position
                else
                    for _, p in pairs(sample:GetChildren()) do
                        if p:IsA("BasePart") then
                            pos = p.Position
                            break
                        end
                    end
                end
            end
            if pos and remoteEvent then
                remoteEvent:FireServer("Batch", {{"Entity", name, pos, workspace.EntityHandler, "Ruins"}})
                remoteEvent:FireServer("Batch", {{"Bug", name, pos, "Wilderness"}})
            end
        end
    end
    maintainExactlySeven("EntityHandler")
end

